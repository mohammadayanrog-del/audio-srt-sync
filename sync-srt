from pydub import AudioSegment
import librosa
import numpy as np
import os
import glob
from natsort import natsorted

TARGET_FRAME_RATE = 44100  # Ensures consistent timing calculations
TARGET_SAMPLE_WIDTH = 2    # 16-bit audio for precision

def parse_time(time_str):
    """Convert SRT time string to milliseconds with millisecond precision."""
    parts = time_str.replace(',', '.').split('.')
    hms_part = parts[0]
    ms_part = parts[1] if len(parts) > 1 else '0'
    ms_part = ms_part.ljust(3, '0')[:3]
    h, m, s = hms_part.split(':')
    return (int(h) * 3600 + int(m) * 60 + int(s)) * 1000 + int(ms_part)

def parse_srt(srt_path):
    """Parse SRT file with enhanced validation for chronological order."""
    entries = []
    with open(srt_path, 'r', encoding='utf-8') as f:
        lines = [line.strip() for line in f.readlines()]
    
    i = 0
    last_end = -1
    while i < len(lines):
        if not lines[i]:
            i += 1
            continue
        
        # Parse entry number
        try:
            entry_num = int(lines[i])
        except ValueError:
            i += 1
            continue
        i += 1

        # Parse timestamps
        if i >= len(lines) or ' --> ' not in lines[i]:
            i += 1
            continue
        start_str, end_str = lines[i].split(' --> ')
        start = parse_time(start_str)
        end = parse_time(end_str)
        
        # Validate chronological order
        if start < last_end:
            raise ValueError(f"Non-chronological order at entry {entry_num}")
        if start >= end:
            raise ValueError(f"Invalid duration at entry {entry_num}")
        last_end = end

        # Skip text content
        i += 1
        while i < len(lines) and lines[i]:
            i += 1
        i += 1

        entries.append({'start': start, 'end': end, 'duration': end - start})
    return entries

def load_audio_resampled(audio_path):
    """Load audio with precise resampling to target frame rate."""
    y, sr = librosa.load(audio_path, sr=TARGET_FRAME_RATE, mono=False)
    
    # Handle mono/stereo format
    if len(y.shape) == 1:
        channels = 1
        y = y.reshape(-1, 1)  # Convert to 2D (samples, channels)
    else:
        channels = y.shape[0]
        y = y.T  # Transpose to (samples, channels)
    
    # Convert to 16-bit PCM
    y_int = (y * 32767).astype(np.int16)
    
    # Create AudioSegment
    if channels == 1:
        y_bytes = y_int.tobytes()
    else:
        y_bytes = y_int.reshape(-1).tobytes()
    
    return AudioSegment(
        data=y_bytes,
        sample_width=TARGET_SAMPLE_WIDTH,
        frame_rate=TARGET_FRAME_RATE,
        channels=channels
    )

def time_stretch(audio_segment, stretch_rate):
    """High-quality time stretching with phase vocoder."""
    samples = np.array(audio_segment.get_array_of_samples())
    original_channels = audio_segment.channels

    # Convert to float32 format for processing
    if TARGET_SAMPLE_WIDTH == 2:
        samples = samples.astype(np.float32) / 32767.0
    else:
        raise ValueError("Unsupported sample width")

    # Process mono/stereo
    if original_channels == 2:
        left = samples[::2]
        right = samples[1::2]
        left_stretched = librosa.effects.time_stretch(left, rate=stretch_rate)
        right_stretched = librosa.effects.time_stretch(right, rate=stretch_rate)
        min_length = min(len(left_stretched), len(right_stretched))
        processed = np.zeros(2 * min_length, dtype=np.float32)
        processed[::2] = left_stretched[:min_length]
        processed[1::2] = right_stretched[:min_length]
    else:
        processed = librosa.effects.time_stretch(samples, rate=stretch_rate)

    # Convert back to 16-bit
    processed = (processed * 32767).astype(np.int16)
    
    return AudioSegment(
        processed.tobytes(),
        frame_rate=TARGET_FRAME_RATE,
        sample_width=TARGET_SAMPLE_WIDTH,
        channels=original_channels
    )

def main(audio_folder, srt_path, output_path):
    """Main synchronization logic with enhanced precision."""
    # Load and validate SRT entries
    srt_entries = parse_srt(srt_path)
    audio_files = natsorted(glob.glob(os.path.join(audio_folder, '*.wav')))
    
    if len(srt_entries) != len(audio_files):
        raise ValueError(f"Mismatch: {len(srt_entries)} SRT entries vs {len(audio_files)} audio files")

    processed_segments = []
    
    for idx, (entry, audio_file) in enumerate(zip(srt_entries, audio_files)):
        # Load and validate audio
        segment = load_audio_resampled(audio_file)
        srt_duration = entry['duration']
        segment_duration = len(segment)

        # Process audio to match SRT duration
        if segment_duration < srt_duration:
            # Append silence to match duration
            silence = AudioSegment.silent(
                duration=srt_duration - segment_duration,
                frame_rate=TARGET_FRAME_RATE
            )
            processed = segment + silence
        elif segment_duration > srt_duration:
            # Time-stretch with precise adjustment
            stretch_factor = segment_duration / srt_duration
            processed = time_stretch(segment, stretch_factor)
            
            # Final micro-adjustments
            processed_duration = len(processed)
            delta = srt_duration - processed_duration
            if delta > 0:
                processed += AudioSegment.silent(delta, frame_rate=TARGET_FRAME_RATE)
            elif delta < 0:
                processed = processed[:srt_duration]
        else:
            processed = segment

        # Verify exact duration match
        if len(processed) != srt_duration:
            raise RuntimeError(f"Duration mismatch: {len(processed)}ms vs {srt_duration}ms")

        processed_segments.append(processed)

        # Add inter-segment silence if needed
        if idx < len(srt_entries) - 1:
            next_start = srt_entries[idx + 1]['start']
            gap = next_start - entry['end']
            if gap > 0:
                processed_segments.append(
                    AudioSegment.silent(gap, frame_rate=TARGET_FRAME_RATE)
                )

    # Concatenate all segments with exact timing
    final_audio = sum(processed_segments[1:], processed_segments[0])
    final_audio.export(output_path, format='wav', parameters=['-ar', str(TARGET_FRAME_RATE)])
    print(f"Successfully created synchronized audio: {output_path}")

if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(description='Synchronize audio with SRT to millisecond precision.')
    parser.add_argument('audio_folder', help='Directory containing ordered WAV files')
    parser.add_argument('srt_path', help='Path to SRT file')
    parser.add_argument('output_path', help='Output WAV file path')
    args = parser.parse_args()

    main(args.audio_folder, args.srt_path, args.output_path)
